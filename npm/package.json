{
  "name": "@assrt-ai/assrt",
  "version": "0.5.0-fazm-dev",
  "description": "AI-powered QA testing from the command line and as an MCP server for coding agents",
  "keywords": [
    "testing",
    "qa",
    "ai",
    "mcp",
    "playwright",
    "browser",
    "claude",
    "automation"
  ],
  "license": "MIT",
  "author": "Assrt <matt@assrt.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assrt-ai/assrt-mcp.git"
  },
  "homepage": "https://assrt.ai",
  "bin": {
    "assrt": "cli.mjs",
    "assrt-mcp": "mcp/server.mjs"
  },
  "main": "index.mjs",
  "exports": {
    ".": "./index.mjs",
    "./cli": "./cli.mjs",
    "./mcp": "./mcp/server.mjs"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
